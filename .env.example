# Order Health Observability: example environment.
# Copy to .env and fill in. Never commit a real .env (see .gitignore).
# Every source below is READ-ONLY. This service adds no mutation path to the
# middleware or to NAV.

# --- This service's own datastore (Postgres) ---
# The snapshot store lives here, never in the middleware.
DATABASE_URL=postgres://order_health:changeme@localhost:5432/order_health

# --- Middleware read-only HTTP endpoints (consumed as an external consumer) ---
# Base URL of the Symmetry warehouse-splitter middleware. We only call its
# EXISTING read-only endpoints (dashboard activity/errors, job-queue/health,
# back-sync/missed-shipments, stuck-staging, pending-fulfillment).
MIDDLEWARE_BASE_URL=https://middleware.internal.grundens.example
MIDDLEWARE_AUTH_TOKEN=replace-with-read-only-token

# --- NAV 18 read-only connection ---
# Read-only NAV access for the IABC watermark, watcher state, allocation and
# shipment detail the middleware endpoints do not expose.
NAV_HOST=nav-sql.internal.grundens.example
NAV_PORT=1433
NAV_DATABASE=GRUNDENS_PROD
NAV_USER=order_health_ro
NAV_PASSWORD=replace-with-read-only-password
NAV_ENCRYPT=true

# --- Aggregator cadence knobs (conservative defaults, Ops-tunable) ---
# Order layer: every 2 to 5 minutes. Inventory layer: aligned to the ~2h IABC
# cycle. Values are cron expressions.
ORDER_LAYER_CRON=*/3 * * * *
INVENTORY_LAYER_CRON=0 */2 * * *
# Set to false to stand up the API without starting the scheduled writer
# (useful before DevOps provisions the read-only source access).
AGGREGATOR_ENABLED=true

# --- Inventory Sync Monitor thresholds (Unit 1, design.md 5A) ---
# The three verdict bands are all tuned here (Ops owns the numbers), never
# hardcoded. Cycle-based bands are multiples of INVENTORY_CYCLE_SECONDS.
# One IABC cycle in seconds (~2h).
INVENTORY_CYCLE_SECONDS=7200
# Watermark freshness: green under 1 cycle, amber 1 to 2 cycles, red beyond.
INVENTORY_FRESHNESS_AMBER_CYCLES=1
INVENTORY_FRESHNESS_RED_CYCLES=2
# Watcher liveness (heartbeat age), independent of freshness. Same bands.
INVENTORY_LIVENESS_AMBER_CYCLES=1
INVENTORY_LIVENESS_RED_CYCLES=2
# Dry-run divergence: (dry-run would-push / trailing live push) above this ratio
# flags AMBER. It is amber-capped and NEVER auto-red (design.md 5A.3).
INVENTORY_DIVERGENCE_AMBER_RATIO=5

# --- Allocator (Warehouse Split) thresholds (Unit 4, design.md 3.2 / 5) ---
# Freshness + liveness are cycle-banded (multiples of ALLOCATOR_CYCLE_SECONDS);
# the split-sanity signal is ratio-banded. Ops owns the numbers.
# One allocator decision window in seconds (~5m).
ALLOCATOR_CYCLE_SECONDS=300
# Decision freshness: green under 3 cycles (~15m), amber 3 to 6, red beyond ~30m.
ALLOCATOR_FRESHNESS_AMBER_CYCLES=3
ALLOCATOR_FRESHNESS_RED_CYCLES=6
# Allocator liveness (heartbeat age), independent of freshness. Same bands.
ALLOCATOR_LIVENESS_AMBER_CYCLES=3
ALLOCATOR_LIVENESS_RED_CYCLES=6
# Split-sanity: share of decisions that are un-allocatable or failed. Amber above
# 5%, red above 15%. NOT amber-capped: a broken allocator is allowed to go red.
ALLOCATOR_FAILED_AMBER_RATIO=0.05
ALLOCATOR_FAILED_RED_RATIO=0.15

# --- Backend HTTP server ---
PORT=8080
HOST=0.0.0.0
