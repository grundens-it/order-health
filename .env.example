# Order Health Observability: example environment.
# Copy to .env and fill in. Never commit a real .env (see .gitignore).
# Every source below is READ-ONLY. This service adds no mutation path to the
# middleware or to NAV.

# --- This service's own datastore (Postgres) ---
# The snapshot store lives here, never in the middleware.
DATABASE_URL=postgres://order_health:changeme@localhost:5432/order_health

# --- Middleware read-only HTTP endpoints (consumed as an external consumer) ---
# Base URL of the Symmetry warehouse-splitter middleware. We only call its
# EXISTING read-only endpoints (dashboard activity/errors, job-queue/health,
# back-sync/missed-shipments, stuck-staging, pending-fulfillment).
MIDDLEWARE_BASE_URL=https://middleware.internal.grundens.example
MIDDLEWARE_AUTH_TOKEN=replace-with-read-only-token

# --- NAV 18 read-only connection (Azure SQL, Microsoft Entra auth) ---
# READ-ONLY NAV access for the IABC watermark, watcher liveness, order lifecycle
# join, and posted-shipment detail. The Entra identity is granted db_datareader
# ONLY; this service issues SELECT statements exclusively (no NAV writes).
NAV_HOST=sql-grus-prd-01.database.windows.net
NAV_PORT=1433
NAV_DATABASE=sqldb-nav18-grus-prd-01
NAV_ENCRYPT=true
# Auth is Microsoft Entra (Azure AD): this server has NO SQL username/password.
# NAV_AUTH_MODE selects the auth type:
#   aad-default          -> local dev via `az login` (ambient Azure credential)
#   aad-service-principal -> tenant + client id + secret (deployed, non-managed)
#   aad-msi              -> managed identity (deployed in Azure App Service)
NAV_AUTH_MODE=aad-default
# Service-principal credentials (ONLY for NAV_AUTH_MODE=aad-service-principal;
# leave blank for aad-default / aad-msi). Must be a db_datareader Entra identity.
NAV_AAD_TENANT_ID=
NAV_AAD_CLIENT_ID=
NAV_AAD_CLIENT_SECRET=
# Multi-company NAV DB: every table is prefixed `${NAV_COMPANY}$`. GRUS = Grundens
# US. Do NOT change without reason; a wrong prefix reads another company's data.
NAV_COMPANY=GRUS
# How many most-recent orders the aggregator ingests from NAV into the snapshot.
# The UI defaults to showing 100 and lets the operator raise the displayed count
# up to this cap, so keep this at or above the UI maximum (1000).
NAV_ORDER_INGEST_LIMIT=1000

# --- Aggregator cadence knobs (Ops-tunable) ---
# These are EVALUATION cadences: how often the aggregator re-checks each layer and
# writes a snapshot, so problems (a stalled sync, a stuck order) surface promptly.
# They are NOT the data cadence: the inventory-sync pipe still bands its freshness
# verdict in ~2h IABC cycles (INVENTORY_CYCLE_SECONDS), so evaluating every few
# minutes just means the freshness age and any stall are caught within minutes
# instead of hours. Both layers cover the whole board (order layer: orders;
# inventory layer: all six pipes). Values are cron expressions.
ORDER_LAYER_CRON=*/3 * * * *
INVENTORY_LAYER_CRON=*/5 * * * *
# Set to false to stand up the API without starting the scheduled writer
# (useful before DevOps provisions the read-only source access).
AGGREGATOR_ENABLED=true

# --- Inventory Sync Monitor thresholds (Unit 1, design.md 5A) ---
# The three verdict bands are all tuned here (Ops owns the numbers), never
# hardcoded. Cycle-based bands are multiples of INVENTORY_CYCLE_SECONDS.
# One IABC cycle in seconds (~2h).
INVENTORY_CYCLE_SECONDS=7200
# Watermark freshness: green under 1 cycle, amber 1 to 2 cycles, red beyond.
INVENTORY_FRESHNESS_AMBER_CYCLES=1
INVENTORY_FRESHNESS_RED_CYCLES=2
# Watcher liveness (heartbeat age), independent of freshness. Same bands.
INVENTORY_LIVENESS_AMBER_CYCLES=1
INVENTORY_LIVENESS_RED_CYCLES=2
# Dry-run divergence: (dry-run would-push / trailing live push) above this ratio
# flags AMBER. It is amber-capped and NEVER auto-red (design.md 5A.3).
INVENTORY_DIVERGENCE_AMBER_RATIO=5

# --- Order-lifecycle grading (Unit 5, design.md 3.1 / 5) ---
# ORPHAN GRADING GATE. Leave FALSE until BA open question 1 (orphan vs wholesale
# disambiguation, design.md section 9) is resolved. While false, no DTC order is
# flagged an orphan for an empty WebId; wholesale is never flagged regardless.
ORDER_ORPHAN_GRADING_ENABLED=false
# Staging/promotion SLO: green under amber, amber up to red, red beyond (seconds).
ORDER_STAGE_AMBER_SECONDS=1800
ORDER_STAGE_RED_SECONDS=3600
# Awaiting-ship SLO (promoted, no NAV shipment yet). 3PL latency is hours/days.
ORDER_AWAITING_SHIP_AMBER_SECONDS=86400
ORDER_AWAITING_SHIP_RED_SECONDS=259200
# --- Allocator (Warehouse Split) thresholds (Unit 4, design.md 3.2 / 5) ---
# Freshness + liveness are cycle-banded (multiples of ALLOCATOR_CYCLE_SECONDS);
# the split-sanity signal is ratio-banded. Ops owns the numbers.
# One allocator decision window in seconds (~5m).
ALLOCATOR_CYCLE_SECONDS=300
# Decision freshness: green under 3 cycles (~15m), amber 3 to 6, red beyond ~30m.
ALLOCATOR_FRESHNESS_AMBER_CYCLES=3
ALLOCATOR_FRESHNESS_RED_CYCLES=6
# Allocator liveness (heartbeat age), independent of freshness. Same bands.
ALLOCATOR_LIVENESS_AMBER_CYCLES=3
ALLOCATOR_LIVENESS_RED_CYCLES=6
# Split-sanity: share of decisions that are un-allocatable or failed. Amber above
# 5%, red above 15%. NOT amber-capped: a broken allocator is allowed to go red.
ALLOCATOR_FAILED_AMBER_RATIO=0.05
ALLOCATOR_FAILED_RED_RATIO=0.15
# --- Price Sync Monitor thresholds (Unit 3, design.md 3) ---
# Freshness (last price-sync received) + liveness (last price-sync run), both
# cycle-banded like inventory-sync. One price-sync cycle in seconds (~1h default).
PRICE_SYNC_CYCLE_SECONDS=3600
PRICE_SYNC_FRESHNESS_AMBER_CYCLES=1
PRICE_SYNC_FRESHNESS_RED_CYCLES=2
PRICE_SYNC_LIVENESS_AMBER_CYCLES=1
PRICE_SYNC_LIVENESS_RED_CYCLES=2

# --- NAV Job Queue Monitor (Unit 3, design.md 6) ---
# The job-queue verdict is CONSUMED from the middleware's job-queue/health
# endpoint and is NOT recomputed here. This only labels the middleware's own
# stuck-job age in the panel (the existing 30-min tripwire); it gates no verdict.
JOB_QUEUE_STUCK_JOB_WARN_SECONDS=1800

# --- Shopify Webhook Monitor thresholds (Unit 3, design.md 5) ---
# Per-topic last-received freshness bands. Expected-delivery window (~1h default).
# A removed/absent webhook subscription is amber-or-worse by rule, not a band.
WEBHOOK_CYCLE_SECONDS=3600
WEBHOOK_FRESHNESS_AMBER_CYCLES=1
WEBHOOK_FRESHNESS_RED_CYCLES=4
# --- Back-sync Monitor thresholds (Unit 2, design.md 3.2 / 5) ---
# Back-sync = NAV shipment (3PL shipped) to Shopify fulfillmentCreate. Freshness
# and liveness are cycle-banded (multiples of BACK_SYNC_CYCLE_SECONDS); the
# missed-shipments signal is count-banded and, unlike inventory divergence, MAY
# reach RED (a real backlog). Ops owns the numbers.
# One back-sync cycle in seconds (back-sync runs far more often than the 2h IABC).
BACK_SYNC_CYCLE_SECONDS=3600
# Watermark freshness (age of last successful fulfillmentCreate): green under 1
# cycle, amber 1 to 2 cycles, red beyond.
BACK_SYNC_FRESHNESS_AMBER_CYCLES=1
BACK_SYNC_FRESHNESS_RED_CYCLES=2
# Watcher liveness (heartbeat age), independent of freshness. Same bands.
BACK_SYNC_LIVENESS_AMBER_CYCLES=1
BACK_SYNC_LIVENESS_RED_CYCLES=2
# Missed-shipments signal: count of NAV shipments posted with no Shopify
# fulfillment over the lookback window. One is AMBER; a cluster reds the pipe.
BACK_SYNC_MISSED_WINDOW_DAYS=14
BACK_SYNC_MISSED_AMBER_COUNT=1
BACK_SYNC_MISSED_RED_COUNT=5

# --- Remediation runbook layer (Unit 7, design.md 5A.4) ---
# Remediation is OPERATOR-triggered only and never auto-fires. This token gates
# the POST /api/remediation/:tool/trigger endpoint in THIS service (send it as
# Authorization: Bearer <token> or x-operator-token). Leave empty in the scaffold
# to allow triggers without provisioning. The actual middleware call is stubbed
# (no live call in v1); it routes to the middleware's EXISTING authenticated
# endpoints (for example recovery.rs) or a documented ops runbook. No new
# middleware endpoint is ever added.
REMEDIATION_OPERATOR_TOKEN=

# --- Backend HTTP server ---
PORT=8080
HOST=0.0.0.0
